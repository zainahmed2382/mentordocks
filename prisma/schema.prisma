generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  role      String?
  createdAt DateTime @default(now())
}

model Audit {
  id             Int      @id @default(autoincrement())
  url            String
  score          Int
  summary        String
  categoryScores String // stored as JSON string
  createdAt      DateTime @default(now())
}
